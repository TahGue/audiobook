# Database (SQLite by default - zero setup)
DATABASE_URL=sqlite:///./audiobook.db
# For PostgreSQL (optional):
# DATABASE_URL=postgresql://audiobook:audiobook@localhost:5434/audiobook

# Storage
AUDIO_DIR=./audio
PIPER_MODELS_DIR=./models

# Server
HOST=0.0.0.0
PORT=8001

# Redis (for async job queue - optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_password_here

# TTS Settings
TTS_CACHE_ENABLED=true
TTS_DEFAULT_ENGINE=piper

# OCR Settings  
OCR_DEFAULT_ENGINE=surya
OCR_FALLBACK_ENGINE=easyocr

# Development
DEBUG=false
LOG_LEVEL=info
